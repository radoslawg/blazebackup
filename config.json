{
  "backups": [
    {
      "name": "my-backup",
      "sources": [
        "c:/bin"
      ],
      "output_filename": "{name}-{timestamp}.7z"
    },
    {
      "name": "configs",
      "sources": [
        "c:/Users/Administrator/.config/"
      ],
      "output_filename": "{name}-{timestamp}.7z"
    },
    {
      "name": "obsidian",
      "sources": [
        "d:/Obsidian/"
      ],
      "output_filename": "{name}-{timestamp}.7z"
    }
  ],
  "storage": {
    "bucket": "radoslawg-Backups",
    "key_prefix": "backups/"
  }
}

